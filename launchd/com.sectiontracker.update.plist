<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.sectiontracker.update</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/wmeleis/committees/nu-docs/Curriculum/SectionTracker/update.sh</string>
  </array>
  <!-- Daily at 06:30 local time. macOS runs a missed job after wake. -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>6</integer>
    <key>Minute</key><integer>30</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>/Users/wmeleis/committees/nu-docs/Curriculum/SectionTracker/data/launchd.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/wmeleis/committees/nu-docs/Curriculum/SectionTracker/data/launchd.log</string>
</dict>
</plist>
